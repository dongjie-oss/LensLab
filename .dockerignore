# 运行时数据（Docker volume 挂载）
data/

# 但保留 VERSIONS.json 模板
!data/VERSIONS.json
!data/VERSIONS.json.bak

# Git
.git/
.gitignore

# 文档和截图（非运行必需）
*.md
*.png
*.jpg
*.jpeg

# 本地环境
.env
.env.local
.vscode/
.idea/
Thumbs.db
.DS_Store

# Python 本地缓存
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
*.egg
.venv/
venv/

# 前端本地 node_modules（CI 中会重新 npm ci）
frontend/node_modules/

# Docker Compose（非构建所需）
docker-compose.yml